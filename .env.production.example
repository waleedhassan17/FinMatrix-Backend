# ==============================================================================
# FinMatrix Backend — PRODUCTION .env TEMPLATE
#
# Copy this file to `.env.production` on your production host (or `.env` inside
# the container) and replace every placeholder with a real value.
# NEVER commit the filled-in file. NEVER reuse dev secrets.
#
# Generate strong secrets on the target host:
#   openssl rand -base64 48   # for JWT_SECRET / JWT_REFRESH_SECRET / COOKIE_SECRET
#   openssl rand -base64 24 | tr -d '/+=' | head -c 24   # for DB_PASSWORD
# ==============================================================================

# ---- App ----
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
APP_NAME=FinMatrix
# Public URL the API is reachable at (used by Swagger & CORS). Include scheme.
APP_URL=https://api.your-domain.com

# ---- Database ----
# For a managed DB (RDS / DigitalOcean / Supabase), set DB_SSL=true.
DB_HOST=REPLACE_WITH_DB_HOST
DB_PORT=5432
DB_USERNAME=REPLACE_WITH_DB_USER
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_NAME=finmatrix
# MUST be false in production. The app forces this regardless, but keep it false here.
DB_SYNCHRONIZE=false
DB_LOGGING=false
# Set to true when connecting to any managed Postgres that requires TLS.
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_MIN=4
# Auto-run migrations on container startup. Safe if your migrations are idempotent.
DB_MIGRATIONS_RUN=true

# ---- JWT ----
JWT_SECRET=REPLACE_WITH_openssl_rand_base64_48
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_openssl_rand_base64_48
JWT_REFRESH_EXPIRES_IN=30d

# ---- Security ----
BCRYPT_ROUNDS=12
# Comma-separated list of allowed frontend origins. NO wildcards in prod.
CORS_ORIGINS=https://app.your-domain.com
THROTTLE_TTL=60
THROTTLE_LIMIT=100
COOKIE_SECRET=REPLACE_WITH_openssl_rand_base64_48

# ---- Logging ----
LOG_LEVEL=info
# Keep pretty=false in prod so logs are JSON (for log aggregators like Datadog, Loki).
LOG_PRETTY=false

# ---- File Uploads ----
UPLOAD_MAX_SIZE_MB=10
UPLOAD_STORAGE_PATH=/app/storage

# ---- Email (enable when SMTP is configured) ----
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@your-domain.com

# ---- Feature Flags ----
# Disable Swagger in prod OR protect the path behind auth / IP allowlist in Nginx.
SWAGGER_ENABLED=false
SWAGGER_PATH=api/docs
