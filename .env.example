# ===== App =====
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_NAME=FinMatrix
APP_URL=http://localhost:3000

# ===== Database (matches docker-compose.yml) =====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=finmatrix_user
DB_PASSWORD=finmatrix_pass_change_me
DB_NAME=finmatrix
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_MIGRATIONS_RUN=false

# ===== JWT =====
JWT_SECRET=generate_48_char_base64_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate_different_48_char_base64_secret
JWT_REFRESH_EXPIRES_IN=30d

# ===== Security =====
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
THROTTLE_TTL=60
THROTTLE_LIMIT=100
COOKIE_SECRET=generate_48_char_base64_secret

# ===== Logging =====
LOG_LEVEL=debug
LOG_PRETTY=true

# ===== File Uploads =====
UPLOAD_MAX_SIZE_MB=5
UPLOAD_STORAGE_PATH=./storage

# ===== Email (optional) =====
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ===== Feature Flags =====
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
