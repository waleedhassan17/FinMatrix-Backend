# ===== App =====
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
APP_NAME=FinMatrix
APP_URL=http://localhost:3000

# ===== Database (matches docker-compose.yml) =====
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=finmatrix_user
DB_PASSWORD=finmatrix_pass_change_me
DB_NAME=finmatrix
DB_SYNCHRONIZE=true
DB_LOGGING=false
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=10
DB_POOL_MIN=2
DB_MIGRATIONS_RUN=false

# ===== JWT =====
JWT_SECRET=generate_48_char_base64_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=generate_different_48_char_base64_secret
JWT_REFRESH_EXPIRES_IN=30d

# ===== Security =====
BCRYPT_ROUNDS=12
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
THROTTLE_TTL=60
THROTTLE_LIMIT=100
COOKIE_SECRET=generate_48_char_base64_secret

# ===== Logging =====
LOG_LEVEL=debug
LOG_PRETTY=true

# ===== File Uploads =====
UPLOAD_MAX_SIZE_MB=5
UPLOAD_STORAGE_PATH=./storage

# ===== Email / SMTP =====
# Leave EMAIL_ENABLED=false for local dev — all emails (verification links,
# OTPs, approval/rejection notices) are printed to the server console instead
# of being sent. Set to true and fill in the SMTP_* values to send real email.
EMAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
# Either SMTP_PASSWORD or SMTP_PASS works.
SMTP_PASSWORD=
SMTP_FROM=FinMatrix <no-reply@finmatrix.pk>

# ===== Deep Links / Email Verification =====
# Custom URL scheme used in verification deep links: finmatrix://verify-email?token=...
APP_DEEP_LINK_SCHEME=finmatrix
# Web fallback page shown when the app is not installed. Defaults to
# <APP_URL>/<API_PREFIX>/auth (which serves GET /auth/verify).
WEB_FALLBACK_URL=http://localhost:3000/api/v1/auth
# How long verification links stay valid.
VERIFICATION_TTL_HOURS=24

# ===== Forgot-Password OTP =====
OTP_TTL_MINUTES=10
OTP_MAX_ATTEMPTS=5

# ===== Platform Admin Seed (npm run seed:superadmin) =====
# Used to seed the PLATFORM_ADMIN (super_admin) account. Never commit real
# secrets — set these locally / in your host's secret manager. Rotate any
# password that has ever been shared in plaintext.
ADMIN_EMAIL=platform-admin@example.com
ADMIN_PASSWORD=change_me_strong_password
ADMIN_NAME=Platform Admin

# ===== Feature Flags =====
SWAGGER_ENABLED=true
SWAGGER_PATH=api/docs
